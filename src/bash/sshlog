#!/bin/bash
#
# SSHlog v1.7
#
# Parses/filters system auth-logs for SSH access requests.
#
# Cats, greps and echoes accepted/failed ssh logins,
# and conditionally, sftp requests from
# '/var/log/auth*' log files.
#
# @author Kim Olsen <pizslacker@pizslacker.org>
#
# v0.9.x   - @lastchange 20120730-22:20-GMT+1
# v1.7.x   - @lastchange 20220808-13:41-GMT+1
#
#!/usr/bin/env bash
#
# sshlog - SSH log analysis tool
# Rewritten to adhere to portable shell scripting standards.

# Exit immediately on uninitialized variables or errors in pipelines
set -uo pipefail

# Initialize variables
filter_accepted=0
filter_failed=0
filter_method=""
output_to_file=0

print_usage() {
    cat <<EOF
Usage: $(basename "$0") [-a] [-f] [-m method] [-o]
  -a         Show only accepted logins
  -f         Show only failed logins
  -m method  Filter by authentication method (e.g., password, publickey)
  -o         Save output to ~/ssh-logs in a timestamped file
  -h         Show this help menu
EOF
}

# Parse command line arguments using standard getopts
while getopts "afm:oh" opt; do
    case "${opt}" in
        a) filter_accepted=1 ;;
        f) filter_failed=1 ;;
        m) filter_method="${OPTARG}" ;;
        o) output_to_file=1 ;;
        h) print_usage; exit 0 ;;
        *) print_usage >&2; exit 1 ;;
    esac
done

# Shift away parsed arguments
shift "$((OPTIND - 1))"

# Handle file output redirection
if [ "$output_to_file" -eq 1 ]; then
    log_dir="${HOME}/ssh-logs"
    
    # Safely create directory
    if ! mkdir -p "$log_dir"; then
        echo "Error: Could not create directory ${log_dir}" >&2
        exit 1
    fi
    
    timestamp=$(date "+%Y%m%d_%H%M%S")
    out_path="${log_dir}/sshlog_${timestamp}.txt"
    
    echo "Output being saved to: ${out_path}" >&2
    
    # Redirect all future standard output (stdout) to this file
    exec > "$out_path"
fi

# Function to read all log files and stream their content
stream_logs() {
    # Loop through all files matching the pattern
    for file in /var/log/auth.log*; do
        # Check if the file actually exists (handles the case where no files match)
        [ -e "$file" ] || continue
        
        # Print the current file being processed to stderr (so it bypasses file output)
        if [ "$output_to_file" -eq 1 ]; then
            echo "Processing: $file" >&2
        fi

        # Use gzip -dc for portable decompression across Linux/macOS/BSD
        case "$file" in
            *.gz) gzip -dc "$file" 2>/dev/null || true ;;
            *)    cat "$file" 2>/dev/null || true ;;
        esac
    done
}

# The awk script performs all filtering in a single, highly efficient process.
# Using 'index()' instead of regex matching for the method prevents issues 
# if the user supplies a method containing special characters.
awk_filter='
/sshd/ {
    match_line = 1
    
    if (filter_accepted == 1 && !/Accepted/) match_line = 0
    if (filter_failed == 1 && !/Failed/) match_line = 0
    if (filter_method != "" && index($0, filter_method) == 0) match_line = 0
    
    if (match_line == 1) {
        print $0
    }
}
'

# Execute the pipeline
stream_logs | awk -v filter_accepted="$filter_accepted" \
                  -v filter_failed="$filter_failed" \
                  -v filter_method="$filter_method" \
                  "$awk_filter"
