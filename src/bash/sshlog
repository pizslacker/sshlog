#!/usr/bin/env bash
#
# sshlog - SSH log analysis tool
# Adheres to portable shell standards with native smart pagination.

set -uo pipefail

filter_accepted=0
filter_failed=0
filter_method=""
output_to_file=0

print_usage() {
    cat <<EOF
Usage: $(basename "$0") [-a] [-f] [-m method] [-o]
  -a         Show only accepted logins
  -f         Show only failed logins
  -m method  Filter by authentication method (e.g., password, publickey)
  -o         Save output to ~/ssh-logs in a timestamped file
  -h         Show this help menu
EOF
}

while getopts "afm:oh" opt; do
    case "${opt}" in
        a) filter_accepted=1 ;;
        f) filter_failed=1 ;;
        m) filter_method="${OPTARG}" ;;
        o) output_to_file=1 ;;
        h) print_usage; exit 0 ;;
        *) print_usage >&2; exit 1 ;;
    esac
done

shift "$((OPTIND - 1))"

# Handle file output redirection
if [ "$output_to_file" -eq 1 ]; then
    log_dir="${HOME}/ssh-logs"
    
    if ! mkdir -p "$log_dir"; then
        echo "Error: Could not create directory ${log_dir}" >&2
        exit 1
    fi
    
    timestamp=$(date "+%Y%m%d_%H%M%S")
    out_path="${log_dir}/sshlog_${timestamp}.txt"
    
    echo "Output being saved to: ${out_path}" >&2
    
    # Redirect stdout for the remainder of the script
    exec > "$out_path"
fi

stream_logs() {
    for file in /var/log/auth.log*; do
        [ -e "$file" ] || continue
        
        # Print to stderr so it bypasses file redirection and pagers
        if [ "$output_to_file" -eq 1 ]; then
            echo "Processing: $file" >&2
        fi

        case "$file" in
            *.gz) gzip -dc "$file" 2>/dev/null || true ;;
            *)    cat "$file" 2>/dev/null || true ;;
        esac
    done
}

awk_filter='
/sshd/ {
    match_line = 1
    
    if (filter_accepted == 1 && !/Accepted/) match_line = 0
    if (filter_failed == 1 && !/Failed/) match_line = 0
    if (filter_method != "" && index($0, filter_method) == 0) match_line = 0
    
    if (match_line == 1) {
        print $0
    }
}
'

# Execute the pipeline and conditionally paginate
if [ "$output_to_file" -eq 0 ] && [ -t 1 ]; then
    # Output is a terminal. Pipe through 'less' for pagination.
    stream_logs | awk -v filter_accepted="$filter_accepted" \
                      -v filter_failed="$filter_failed" \
                      -v filter_method="$filter_method" \
                      "$awk_filter" | less -FRX
else
    # Output is a file, or piped to another tool (like grep), skip pager
    stream_logs | awk -v filter_accepted="$filter_accepted" \
                      -v filter_failed="$filter_failed" \
                      -v filter_method="$filter_method" \
                      "$awk_filter"
fi
